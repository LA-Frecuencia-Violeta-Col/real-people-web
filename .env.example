# ============================================================
# Real People Web — Variables de Entorno
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo .env a Git (ya está en .gitignore).
# ============================================================

# ─── Administración ─────────────────────────────────────────
# Contraseña del panel de administración del sitio.
# Cámbiala por algo seguro antes de ir a producción.
ADMIN_PASSWORD=cambia_esta_clave_segura

# Clave secreta para firmar los tokens JWT de sesión.
# Genera una clave aleatoria larga (mínimo 32 caracteres).
JWT_SECRET=clave_secreta_jwt_muy_larga_y_aleatoria

# ─── Cloudflare R2 (Almacenamiento de archivos) ─────────────
# Endpoint de tu cuenta R2:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com

# Credenciales del token API de R2 (Object Read & Write):
R2_ACCESS_KEY_ID=tu_r2_access_key_id
R2_SECRET_ACCESS_KEY=tu_r2_secret_access_key

# Nombre del bucket de R2 donde se guardarán los archivos:
R2_BUCKET=media

# URL pública del bucket R2 (SÍ puede ir al frontend como VITE_):
#   Encuéntrala en: R2 → tu bucket → Settings → Public Access
VITE_R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# ─── Cloudflare KV (Base de datos de configuración) ─────────
# ID de tu cuenta de Cloudflare (encuéntralo en el dashboard principal):
CLOUDFLARE_ACCOUNT_ID=tu_cloudflare_account_id

# Token API de Cloudflare con permisos de lectura/escritura en Workers KV:
#   Crea uno en: Mi perfil → Tokens de API → Crear token
#   Permisos necesarios: Workers KV Storage:Edit
CLOUDFLARE_API_TOKEN=tu_cloudflare_api_token

# ID del namespace KV que crees para este proyecto:
#   Crea uno en: Workers & Pages → KV → Create namespace
#   Nombre sugerido: "real-people-config"
CLOUDFLARE_KV_NAMESPACE_ID=tu_kv_namespace_id
